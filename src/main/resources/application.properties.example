# Copia este archivo como application.properties y completa tus valores locales.
# cp src/main/resources/application.properties.example src/main/resources/application.properties

server.servlet.session.timeout=30m
server.servlet.session.cookie.secure=false
server.servlet.session.cookie.http-only=true
server.servlet.session.cookie.same-site=lax
server.port=8080

spring.application.name=servidorproyecto

spring.datasource.url=jdbc:postgresql://localhost:5432/eventorganizer_uce
spring.datasource.username=postgres
spring.datasource.password=TU_PASSWORD_DB
spring.datasource.driver-class-name=org.postgresql.Driver

spring.jpa.hibernate.ddl-auto=update
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.open-in-view=false

spring.thymeleaf.cache=false
spring.thymeleaf.encoding=UTF-8
spring.thymeleaf.mode=HTML

logging.level.root=INFO
logging.level.com.uce.servidorproyecto=DEBUG

spring.servlet.multipart.max-file-size=5MB
spring.servlet.multipart.max-request-size=5MB

claude.api.key=
claude.api.url=https://api.anthropic.com/v1/messages

gemini.api.key=
gemini.api.url=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash-lite:generateContent

groq.api.key=
groq.api.model=llama-3.3-70b-versatile

ia.provider=groq

# Admin interno (solo desarrollo; en prod usar variables de entorno)
app.admin.path-prefix=/internal
app.admin.seed-enabled=${ADMIN_SEED_ENABLED:false}
app.admin.seed-email=${ADMIN_EMAIL:}
app.admin.seed-password=${ADMIN_PASSWORD:}

app.brand.name=Flowday
app.brand.tagline=Plan your day, own your flow.
app.brand.primary-color=#5082ef
app.brand.logo-url=/images/flowday-logo.svg
app.brand.support-email=support@flowday.app

# OAuth (Fase 5) — deja vacío para desactivar
app.oauth.google-client-id=${GOOGLE_CLIENT_ID:}
app.oauth.google-client-secret=${GOOGLE_CLIENT_SECRET:}
app.oauth.microsoft-client-id=${MICROSOFT_CLIENT_ID:}
app.oauth.microsoft-client-secret=${MICROSOFT_CLIENT_SECRET:}

